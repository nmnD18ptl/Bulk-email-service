# ── Bulk Email Pro — environment variables ────────────────────────────────────
# Copy this file to .env and fill in every value before running locally or
# deploying.  NEVER commit .env to git.
#
# In Railway: add these under your service → Variables tab.
# In Vercel:  add NEXT_PUBLIC_* or plain variables under Project → Settings → Environment Variables.

# ─────────────────────────────────────────────────────────────────────────────
# Spring Boot
# ─────────────────────────────────────────────────────────────────────────────

SPRING_PROFILES_ACTIVE=prod

# Port — Railway sets this automatically; the default below is used locally.
PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL  →  Neon  (https://neon.tech)
#
# 1. Create a project at neon.tech
# 2. Copy the connection string from Dashboard → Connection Details
# 3. Switch the prefix from postgresql:// to jdbc:postgresql://
# 4. Neon always requires SSL; the URL already includes ?sslmode=require
# ─────────────────────────────────────────────────────────────────────────────

DB_URL=jdbc:postgresql://<host>.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=<your-neon-password>

# HikariCP pool — keep low for Neon free tier (max 10 connections).
DB_POOL_MAX=5
DB_POOL_MIN=1

# ─────────────────────────────────────────────────────────────────────────────
# Redis  →  Upstash  (https://upstash.com)
#
# 1. Create a Redis database at upstash.com
# 2. Copy the "REST URL" — it starts with rediss:// (double-s = TLS)
# 3. Paste the full URL as REDIS_URL below
# ─────────────────────────────────────────────────────────────────────────────

REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

REDIS_POOL_MAX=5
REDIS_POOL_MIN=1

# ─────────────────────────────────────────────────────────────────────────────
# RabbitMQ  →  CloudAMQP  (https://www.cloudamqp.com)
#
# 1. Create a "Little Lemur" (free) instance at cloudamqp.com
# 2. Open instance details → copy the AMQP URL
# 3. The URL starts with amqps:// (double-s = TLS)
# ─────────────────────────────────────────────────────────────────────────────

RABBITMQ_URL=amqps://<user>:<pass>@<host>.cloudamqp.com/<vhost>

# Optional: override default prefetch (5) if you need higher throughput.
# RABBITMQ_PREFETCH=5

# ─────────────────────────────────────────────────────────────────────────────
# Security
# IMPORTANT: generate these with a password manager or:
#   openssl rand -base64 48
# Both values must be at least 32 characters.
# ─────────────────────────────────────────────────────────────────────────────

JWT_SECRET=<min-32-char-random-string-replace-me>
ENCRYPTION_KEY=<min-32-char-random-string-replace-me>

# JWT expiry in milliseconds.  3600000 = 1 hour (recommended for production).
JWT_EXPIRY_MS=3600000

# ─────────────────────────────────────────────────────────────────────────────
# CORS
#
# Set to your Vercel deployment URL(s).  Separate multiple origins with commas.
# The wildcard pattern (https://*.vercel.app) covers preview deployments.
# ─────────────────────────────────────────────────────────────────────────────

CORS_ORIGINS=https://<your-project>.vercel.app,https://*.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# Application URLs
#
# Both should point to the Railway backend's public URL.
# Used in email headers (List-Unsubscribe, tracking pixels, click links).
# ─────────────────────────────────────────────────────────────────────────────

TRACKING_BASE_URL=https://<your-app>.railway.app
UNSUBSCRIBE_BASE_URL=https://<your-app>.railway.app

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Vercel)  —  set these in Vercel's environment variable panel,
# not in this file.  Listed here for reference.
# ─────────────────────────────────────────────────────────────────────────────

# NEXT_PUBLIC_API_URL=https://<your-app>.railway.app
# or for Angular environments:
# API_URL=https://<your-app>.railway.app
